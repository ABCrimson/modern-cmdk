{
  "name": "@crimson_dev/command",
  "version": "0.10.0",
  "type": "module",
  "description": "Framework-agnostic headless command palette engine",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "keywords": [
    "command-palette",
    "command-menu",
    "cmdk",
    "headless",
    "state-machine"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ABCrimson/modern-cmdk",
    "directory": "packages/command"
  },
  "dependencies": {
    "idb-keyval": "6.2.2"
  }
}
