{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "nursery": {
        "useExplicitType": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "error",
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noBarrelFile": "error",
        "noReExportAll": "error"
      },
      "suspicious": {
        "noConsole": "warn",
        "noAssignInExpressions": "warn",
        "noDuplicateCustomProperties": "off",
        "noDuplicateProperties": "off",
        "useIterableCallbackReturn": "warn"
      },
      "a11y": {
        "useSemanticElements": "off",
        "useKeyWithClickEvents": "off",
        "useFocusableInteractive": "off",
        "useAriaPropsForRole": "off",
        "useButtonType": "error"
      },
      "style": {
        "useImportType": "error",
        "useTemplate": "error",
        "useExponentiationOperator": "error",
        "noNonNullAssertion": "warn"
      }
    },
    "domains": {
      "test": "all"
    }
  },
  "overrides": [
    {
      "includes": [
        "benchmarks/**",
        "apps/playground/**",
        "tests/unit/cmdk-performance-accuracy.test.tsx"
      ],
      "linter": {
        "rules": {
          "nursery": {
            "useExplicitType": "off"
          },
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/docs/**/*.css"],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "warn"
          }
        }
      }
    },
    {
      "includes": ["**/index.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/command-codemod/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "warn"
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": { "level": "on" }
      }
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "single",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSameLine": false
    },
    "globals": ["Temporal"]
  },
  "css": {
    "formatter": {
      "enabled": true
    },
    "linter": {
      "enabled": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!dist/",
      "!*.wasm",
      "!coverage/",
      "!.changeset/",
      "!node_modules/",
      "!packages/command-react/src/primitives.ts"
    ]
  }
}
