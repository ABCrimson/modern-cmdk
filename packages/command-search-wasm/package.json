{
  "name": "modern-cmdk-search-wasm",
  "version": "0.9.0",
  "type": "module",
  "description": "Optional WASM-accelerated fuzzy search for modern-cmdk (not yet published — requires wasm-pack)",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build": "[ -f pkg/command_search_wasm.js ] && tsdown || echo 'Skipping WASM build (run build:wasm first)'",
    "build:wasm": "wasm-pack build crate --target web --out-dir ../pkg",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "peerDependencies": {
    "modern-cmdk": "workspace:>=1.0.2"
  },
  "keywords": [
    "wasm",
    "fuzzy-search",
    "trigram",
    "command-palette"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ABCrimson/modern-cmdk",
    "directory": "packages/command-search-wasm"
  }
}
