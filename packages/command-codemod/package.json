{
  "name": "@crimson_dev/command-codemod",
  "version": "0.9.0",
  "type": "module",
  "description": "Codemods for migrating from cmdk to @crimson_dev/command-react",
  "license": "MIT",
  "bin": {
    "command-codemod": "./dist/cli.mjs"
  },
  "exports": {
    "./transforms/*": "./dist/transforms/*.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/cli.ts src/transforms/*.ts --format esm --dts"
  },
  "dependencies": {
    "globby": "16.1.1",
    "jscodeshift": "17.3.0"
  },
  "devDependencies": {
    "@types/jscodeshift": "^17.3.0",
    "tsdown": "0.21.0",
    "typescript": "6.0.1-rc"
  },
  "engines": {
    "node": ">=25.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ABCrimson/modern-cmdk",
    "directory": "packages/command-codemod"
  }
}
