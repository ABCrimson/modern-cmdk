{
  "Command Palette (Basic)": {
    "prefix": "cmd-basic",
    "body": [
      "import { Command } from '@crimson_dev/command-react';",
      "",
      "function ${1:CommandPalette}() {",
      "  return (",
      "    <Command label=\"${2:Command menu}\">",
      "      <Command.Input placeholder=\"${3:Search...}\" />",
      "      <Command.List>",
      "        <Command.Empty>No results found.</Command.Empty>",
      "        <Command.Item value=\"${4:action}\" onSelect={() => ${5:console.log('selected')}}>",
      "          ${6:Action}",
      "        </Command.Item>",
      "      </Command.List>",
      "    </Command>",
      "  );",
      "}"
    ],
    "description": "Basic inline command palette"
  },
  "Command Dialog": {
    "prefix": "cmd-dialog",
    "body": [
      "import { Command } from '@crimson_dev/command-react';",
      "",
      "function ${1:CommandDialog}() {",
      "  return (",
      "    <Command.Dialog>",
      "      <Command.Input placeholder=\"${2:Search commands...}\" />",
      "      <Command.List>",
      "        <Command.Empty>No results found.</Command.Empty>",
      "        $0",
      "      </Command.List>",
      "    </Command.Dialog>",
      "  );",
      "}"
    ],
    "description": "Command palette in a dialog overlay"
  },
  "Command Item": {
    "prefix": "cmd-item",
    "body": [
      "<Command.Item value=\"${1:value}\" onSelect={() => ${2:console.log('selected')}}>",
      "  ${3:Label}",
      "</Command.Item>"
    ],
    "description": "Command palette item"
  },
  "Command Group": {
    "prefix": "cmd-group",
    "body": ["<Command.Group heading=\"${1:Group}\">", "  $0", "</Command.Group>"],
    "description": "Command palette group"
  },
  "Command with Frecency": {
    "prefix": "cmd-frecency",
    "body": [
      "<Command frecency={{ enabled: true, storage: '${1|indexeddb,memory|}' }}>",
      "  <Command.Input placeholder=\"${2:Search...}\" />",
      "  <Command.List>",
      "    $0",
      "  </Command.List>",
      "</Command>"
    ],
    "description": "Command palette with frecency ranking"
  },
  "Command AsyncItems": {
    "prefix": "cmd-async",
    "body": [
      "import { Suspense } from 'react';",
      "",
      "<Suspense fallback={<Command.Loading>${1:Loading...}</Command.Loading>}>",
      "  <Command.AsyncItems load={${2:fetchItems}} />",
      "</Suspense>"
    ],
    "description": "Async items with Suspense"
  },
  "useCommand Hook": {
    "prefix": "cmd-hook",
    "body": [
      "import { useCommand } from '@crimson_dev/command-react';",
      "",
      "const { state, send } = useCommand({",
      "  items: [$0],",
      "});"
    ],
    "description": "useCommand hook for headless usage"
  },
  "Command Machine (Core)": {
    "prefix": "cmd-machine",
    "body": [
      "import { createCommandMachine, itemId } from '@crimson_dev/command';",
      "",
      "using machine = createCommandMachine({",
      "  items: [",
      "    { id: itemId('${1:action}'), value: '${2:Action}', onSelect: () => ${3:{}} },",
      "  ],",
      "});",
      "",
      "machine.subscribe(() => {",
      "  const state = machine.getState();",
      "  $0",
      "});"
    ],
    "description": "Core state machine (framework-agnostic)"
  },
  "Command Shortcut": {
    "prefix": "cmd-shortcut",
    "body": [
      "<Command.Item",
      "  value=\"${1:action}\"",
      "  shortcut=\"${2:Ctrl+Shift+P}\"",
      "  onSelect={() => ${3:console.log('selected')}}",
      ">",
      "  ${4:Action}",
      "  <Command.Shortcut>${2:Ctrl+Shift+P}</Command.Shortcut>",
      "</Command.Item>"
    ],
    "description": "Command item with keyboard shortcut"
  },
  "Command Page": {
    "prefix": "cmd-page",
    "body": [
      "<Command.Page id=\"${1:page-id}\">",
      "  <Command.Item value=\"${2:back}\" onSelect={() => ${3:goBack()}}>",
      "    Back",
      "  </Command.Item>",
      "  $0",
      "</Command.Page>"
    ],
    "description": "Command palette page (nested navigation)"
  }
}
