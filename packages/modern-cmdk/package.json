{
  "name": "modern-cmdk",
  "version": "1.0.2",
  "type": "module",
  "description": "The definitive command palette engine for the modern web",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core/index.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react/index.mjs"
    },
    "./styles.css": "./src/react/styles.css"
  },
  "main": "./dist/core/index.mjs",
  "types": "./dist/core/index.d.mts",
  "bin": {
    "modern-cmdk": "./dist/codemod/cli.mjs"
  },
  "files": [
    "dist",
    "src/react/styles.css"
  ],
  "scripts": {
    "build": "tsdown src/core/index.ts src/react/index.ts --format esm --dts && tsdown src/codemod/cli.ts src/codemod/transforms/*.ts --format esm --dts --out-dir dist/codemod",
    "dev": "tsdown src/core/index.ts src/react/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": [
    "./src/react/styles.css"
  ],
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "idb-keyval": "6.2.2",
    "radix-ui": "1.4.4-rc.1766004502650"
  },
  "devDependencies": {
    "globby": "16.1.1",
    "jscodeshift": "17.3.0",
    "@types/jscodeshift": "^17.3.0"
  },
  "keywords": [
    "command-palette",
    "command-menu",
    "cmdk",
    "headless",
    "state-machine",
    "react",
    "react-19"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ABCrimson/modern-cmdk",
    "directory": "packages/modern-cmdk"
  }
}
