{
  "name": "@crimson_dev/command-react",
  "version": "0.9.0",
  "type": "module",
  "description": "React 19 adapter for @crimson_dev/command",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src/styles.css": "./src/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles.css"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@crimson_dev/command": "workspace:>=0.9.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "radix-ui": "1.4.4-rc.1766004502650"
  },
  "keywords": [
    "command-palette",
    "react",
    "react-19",
    "cmdk",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ABCrimson/modern-cmdk",
    "directory": "packages/command-react"
  }
}
